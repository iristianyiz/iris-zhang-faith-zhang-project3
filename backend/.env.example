PORT=8000

# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/sudoku-app

# Atlas (replace YOUR_PASSWORD and keep a database name in the path, e.g. /sudoku-app):
# MONGODB_URI=mongodb+srv://admin:YOUR_PASSWORD@cluster0.lgpjrlw.mongodb.net/sudoku-app?retryWrites=true&w=majority&appName=Cluster0

MONGODB_URI=mongodb://127.0.0.1:27017/sudoku-app

# Required for signed sessions in production; use a long random string locally too.
SESSION_SECRET=change-me-to-a-long-random-string

# SKIP_MONGO=1
